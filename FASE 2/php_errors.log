	fmt.Println("len(texto):", len(texto))


	// ==========================================
	// 4.3 now()
	// ==========================================
	fmt.Println("\n--- 4.3 NOW ---")
	fmt.Println("Fecha actual:", now())

	// ==========================================
	// 4.4 substr()
	// ==========================================
