    fmt.Println("Factorial de 5:", fact)

    // ==========================================
    // 3.6 Función recursiva con múltiple retorno
    // ==========================================
    fmt.Println("\n--- 3.6 FUNCION RECURSIVA (MULTIPLE RETORNO) ---")
